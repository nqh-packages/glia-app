{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GliaInput",
  "description": "Structured room snapshot sent to Gemini for shared discussion analysis",
  "type": "object",
  "required": ["room", "opinions"],
  "properties": {
    "room": {
      "type": "object",
      "required": ["topic", "participant_count"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Short join code for the room"
        },
        "topic": {
          "type": "string",
          "description": "The subject being debated"
        },
        "description": {
          "type": "string",
          "description": "Optional extra framing from the host"
        },
        "language": {
          "type": "string",
          "description": "Preferred language for the room and result"
        },
        "participant_count": {
          "type": "integer",
          "description": "Number of people currently in the room"
        }
      }
    },
    "opinions": {
      "type": "array",
      "description": "Submitted participant responses to the main statement, plus secondary reaction signals",
      "items": {
        "type": "object",
        "required": ["opinion_id", "participant", "choice", "yes_count", "neutral_count", "no_count"],
        "properties": {
          "opinion_id": {
            "type": "string",
            "description": "Stable opinion identifier"
          },
          "participant": {
            "type": "string",
            "description": "Anonymized participant label"
          },
          "choice": {
            "type": "string",
            "enum": ["yes", "neutral", "no"],
            "description": "The participant's explicit answer to the host's main statement"
          },
          "reason": {
            "type": "string",
            "description": "Optional explanation for why the participant chose that answer"
          },
          "yes_count": {
            "type": "integer",
            "description": "Current yes reaction total"
          },
          "neutral_count": {
            "type": "integer",
            "description": "Current neutral reaction total"
          },
          "no_count": {
            "type": "integer",
            "description": "Current no reaction total"
          },
          "reaction_reasons": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["yes", "neutral", "no"]
                },
                "reason": {
                  "type": "string"
                }
              }
            },
            "description": "Optional explanations attached to reactions"
          },
          "attachment_count": {
            "type": "integer",
            "description": "How many attachments were submitted with the opinion"
          }
        }
      }
    }
  }
}
